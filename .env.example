SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-app.onrender.com

# Database (Render provides DATABASE_URL automatically)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Al Ansaar Foundation <info@yourdomain.com>

SITE_URL=https://yourdomain.com
SITE_NAME=Al Ansaar Event Management

DISCOUNT_APPROVAL_EMAILS=admin@yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# FNB Banking Integration
FNB_CLIENT_ID=
FNB_CLIENT_SECRET=
FNB_BASE_URL=https://api.p.fnb.co.za/apigateway
FNB_DEBTOR_ACCOUNT=
FNB_DEBTOR_BRANCH=
